# Yandex Maps API (обязательно)
YANDEX_MAPS_API_KEY=your_api_key_here

# Cache Settings
CACHE_DIR=~/.construction_maps_mcp
CACHE_MAX_SIZE_MB=500

# Rate Limiting
YANDEX_RATE_LIMIT_RPM=15
ROSREESTR_RATE_LIMIT_RPM=30

# Cache TTL (в днях)
CACHE_TTL_CADASTRE_DAYS=30
CACHE_TTL_GEOCODE_DAYS=7
CACHE_TTL_INFRASTRUCTURE_DAYS=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
